[Unit]
Description=AI Router Gateway
After=network.target

[Service]
User=airouter
Group=airouter
WorkingDirectory=/opt/ai-router
EnvironmentFile=/opt/ai-router/.env
ExecStart=/opt/ai-router/.venv/bin/uvicorn middleware.app:app --host 127.0.0.1 --port 4000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
