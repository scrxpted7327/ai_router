# Copy this to /opt/ai-router/.env on the server and fill in your keys.
# Never commit this file.

# ── Server ────────────────────────────────────────────────────────────────────
HTTPS=true
COOKIE_SECRET=REPLACE_WITH_RANDOM_64_CHAR_STRING
SESSION_DAYS=7
LOG_LEVEL=INFO
# Comma-separated origins for browser clients, or * for dev only
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Compaction ────────────────────────────────────────────────────────────────
COMPACTION_THRESHOLD=8
PRESERVE_TAIL=3

# ── Provider Keys ─────────────────────────────────────────────────────────────
# Pi-mono OAuth: run `pi login` locally, then `python pi_auth.py` or `./deploy/sync_pi_env.sh`
# (writes ANTHROPIC_*, GITHUB_COPILOT_*, OPENAI_CODEX_*, GEMINI_*, GEMINI_ANTIGRAVITY_* from ~/.pi/agent/auth.json).
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GITHUB_COPILOT_TOKEN=
OPENAI_CODEX_API_KEY=
OPENAI_CODEX_BASE_URL=
GEMINI_API_KEY=
GEMINI_ANTIGRAVITY_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
ZAI_API_KEY=
KILO_API_KEY=
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://api.opencode.ai/v1
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_BASE_URL=https://api.minimaxi.chat/v1
BRAVE_API_KEY=
