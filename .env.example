# ── Core / Gateway ────────────────────────────────────────────────────────────
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-gateway-changeme

# ── First-party model providers ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ── Code / Reasoning specialists ──────────────────────────────────────────────
GROQ_API_KEY=gsk_...
CEREBRAS_API_KEY=...
DEEPSEEK_API_KEY=...
XAI_API_KEY=xai-...
MISTRAL_API_KEY=...

# ── Search-augmented ──────────────────────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-...

# ── Aggregators / Gateways ────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
TOGETHER_API_KEY=...
FIREWORKS_API_KEY=...
COHERE_API_KEY=...

# ── OAuth / pi-mono providers ─────────────────────────────────────────────────
GITHUB_COPILOT_TOKEN=ghp_...        # refreshed by pi_auth.py --login

# ── Boutique providers ────────────────────────────────────────────────────────
ZAI_API_KEY=...
KILO_API_KEY=...
OPENCODE_API_KEY=...
OPENCODE_BASE_URL=https://api.opencode.ai/v1
OPENCODE_ZEN_API_KEY=...
OPENCODE_ZEN_BASE_URL=https://api.minimaxi.chat/v1

# ── Amazon Bedrock ────────────────────────────────────────────────────────────
# Activates when AWS_REGION + one of the auth methods below are set
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=
# AWS_BEARER_TOKEN_BEDROCK=
# BEDROCK_MODELS=anthropic.claude-3-5-sonnet-20241022-v2:0,anthropic.claude-3-5-haiku-20241022-v1:0

# ── Gateway auth (cookie sessions + Bearer tokens) ────────────────────────────
# Create tokens: python manage_users.py token-create you@example.com
# CORS: comma-separated origins, or * for local dev only
# CORS_ORIGINS=https://app.example.com

# ── Tuning ────────────────────────────────────────────────────────────────────
COMPACTION_THRESHOLD=8    # compact after this many non-system messages
PRESERVE_TAIL=3           # keep last N messages verbatim after compaction
LOG_LEVEL=INFO
