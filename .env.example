# ── LiteLLM Proxy ─────────────────────────────────────────────────────────────
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-gateway-changeme

# ── Provider Keys ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GITHUB_COPILOT_TOKEN=ghp_...          # GitHub Copilot / Cursor Pro

# Temporary Codex Plan (GPT-5.4)
OPENAI_CODEX_API_KEY=sk-...
OPENAI_CODEX_BASE_URL=https://api.openai.com/v1   # update to Codex plan endpoint

# OpenCode Zen (MiniMax m2.5)
OPENCODE_ZEN_API_KEY=...
OPENCODE_ZEN_BASE_URL=https://api.minimaxi.chat/v1

# Amazon Bedrock
# Uses the standard AWS credential chain or AWS_BEARER_TOKEN_BEDROCK
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_PROFILE=
# AWS_BEARER_TOKEN_BEDROCK=
# BEDROCK_MODELS=anthropic.claude-3-5-sonnet-20241022-v2:0,anthropic.claude-3-5-haiku-20241022-v1:0

# ── Gateway (users call /v1 with this Bearer token OR browser cookie session) ─
# Create: python manage_users.py token-create you@example.com
# CORS: comma-separated origins, or * for local dev only
# CORS_ORIGINS=https://app.example.com

# ── Tuning ────────────────────────────────────────────────────────────────────
COMPACTION_THRESHOLD=8    # compact after this many non-system messages
PRESERVE_TAIL=3           # keep last N messages verbatim after compaction
LOG_LEVEL=INFO

# ── Optional: Postgres audit log ──────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/ai_router
